{
  "manifest_version": 3,
  "name": "AnyAI",
  "version": "1.2.0",
  "description": "AnyAI crypto radar — real-time prices, premium, funding rates, open interest, sentiment and TD signals from anyai.network",
  "permissions": ["storage", "alarms", "sidePanel"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html?sidepanel=1"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
