{
  "manifest_version": 3,
  "name": "AnyAI Radar",
  "version": "1.0.0",
  "description": "AnyAI Radar: non-custodial AI auto-trading platform. Real-time crypto prices, funding rates, sentiment and market intelligence by AnyAI.",
  "permissions": ["storage", "alarms", "sidePanel"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html?sidepanel=1"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
